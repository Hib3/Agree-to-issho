{
  "name": "aguri-cleanroom",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint . --max-warnings 0",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "validate:data": "tsx scripts/validate-data.ts",
    "verify:cleanroom": "tsx scripts/verify-cleanroom.ts",
    "verify:pwa": "tsx scripts/verify-pwa-build.ts",
    "test": "vitest run",
    "test:dialogue": "vitest run src/tests/semanticComposition.test.ts src/tests/conversationQuality.test.ts src/tests/aguriVoice.test.ts src/tests/narrativeConversation.test.ts src/tests/learningAttributes.test.ts src/tests/storyArcGenerator.test.ts src/tests/newsExplanation.test.ts src/tests/slotResolver.test.ts",
    "test:rss": "vitest run src/tests/rssParser.test.ts src/tests/newsService.test.ts src/tests/articleDigestService.test.ts",
    "test:news": "vitest run src/tests/newsExplanation.test.ts src/tests/newsCorpus.test.ts src/tests/articleDigestService.test.ts",
    "simulate:dialogue": "tsx scripts/simulate-dialogue.ts",
    "simulate:news": "tsx scripts/simulate-news.ts",
    "audit:golden": "tsx scripts/generate-golden-review.ts",
    "test:e2e": "playwright test",
    "build": "npm run validate:data && npm run verify:cleanroom && tsc --noEmit && vite build && npm run verify:pwa",
    "preview": "vite preview"
  },
  "dependencies": {
    "dexie": "^4.2.1",
    "lucide-react": "^1.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^6.4.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "workbox-window": "^7.4.0"
  }
}
